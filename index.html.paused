<!-- Slides -->
<div class="slide-container" id="slideContainer">


<!-- ===== 封面：中式禅意 · 文字居中 ===== -->

    <div class="slide slide-cover" id="s0">
  <div class="zen-bg"></div>
  <div class="zen-line"></div>
  <div class="slide-inner cover-inner">
    <div class="cover-top-spacer"></div>
    <div style="text-align:center;">
      <div style="font-size:0.7em;letter-spacing:.5em;color:var(--zen-green);margin-bottom:1.2em;">浙江 · 东阳 · 虎鹿镇</div>
      <h1 style="font-family:'Ma Shan Zheng',cursive;font-size:1.8em;letter-spacing:.15em;line-height:1.4;color:var(--ink-dark);">虎峰禅寺改扩建项目<br>概念方案初稿</h1>
    </div>
    <div class="cover-meta"><span>2026年6月</span></div>
    <div class="cover-footer-inner"><img src="https://cdn.jsdelivr.net/gh/YUANGOU-LB/HuFeng-Temple@c0388ed/images/img_001.png" alt="原构"></div>
