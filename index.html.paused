<div class="slide slide-content" id="s_case_full_2">
  <div class="slide-inner">
    <div " style="display:none">lass="slide-header">
      <div class="slide-title" style="display:none">案例分析 · 山寺布局</div>
      <div class="slide-pn">19</div>
