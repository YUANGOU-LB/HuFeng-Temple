<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=3.0, user-scalable=yes">
<title>虎峰禅寺改扩建项目概念方案初稿</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=Ma+Shan+Zheng&display=swap');

:root {
  --ink-dark: #333;
  --ink-mid: #5a5a5a;
  --ink-light: #888;
  --ink-faint: #bbb;
  --paper: #faf8f3;
  --paper-dark: #f0ece3;
  --zen-green: #6b7c5e;
  --zen-green-light: #8a9d7a;
  --bamboo: #a3b18a;
  --stone: #9a8c7a;
}

* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; overflow-x: hidden; -webkit-text-size-adjust: 100%; touch-action: pan-x pan-y pinch-zoom; }

body { -webkit-user-select:none; -moz-user-select:none; -ms-user-select:none; user-select:none;
  -webkit-touch-callout:none;
  -webkit-tap-highlight-color:transparent;
  touch-action: pan-x pan-y pinch-zoom;
  font-family: 'Noto Serif SC', 'Songti SC', serif;
  background: #e8e4dd;
  color: var(--ink-dark);
  overflow-x: hidden;
  font-size: 15px;
  line-height: 1.7;
}

/* ===== Scroll Mode - Mobile Optimized ===== */
.scroll-mode .slide-container {
  display: flex; flex-direction: column;
  padding: 0 0 2rem 0;
  gap: 0;
}

.scroll-mode .slide {
  width: 100%;
  scroll-margin-top: 4.5rem;
  background: var(--paper);
  position: relative; overflow: hidden;
  border-bottom: 3px solid #e8e4dd;
}

/* ===== Presentation Mode - Disabled ===== */
.present-overlay, .present-close, .present-nav { display: none !important; }

/* ===== Slide Base ===== */
.slide { font-size: 15px; position: relative; }

.slide-inner {
  width: 100%;
  padding: 1.2rem 1rem;
  display: flex; flex-direction: column;
}

/* ===== Cover ===== */
.slide-cover {
  background: var(--paper);
  position: relative;
  display: flex; flex-direction: column;
  min-height: 70vh;
  justify-content: center;
}
.slide-cover .zen-bg {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background:
    radial-gradient(ellipse at 80% 50%, rgba(163,177,138,.08) 0%, transparent 50%),
    radial-gradient(ellipse at 20% 80%, rgba(154,140,122,.06) 0%, transparent 40%);
  pointer-events: none;
}
.slide-cover .zen-line {
  position: absolute; top: 8%; left: 5%;
  width: 1px; height: 84%;
  background: linear-gradient(180deg, transparent, var(--bamboo), transparent);
  opacity: .3;
}
.slide-cover .cover-meta {
  margin-top: 1.2em;
  font-size: .6em; color: var(--ink-light);
  letter-spacing: .1em;
}
.slide-cover .slide-inner {
  justify-content: center;
  text-align: center;
  padding: 2rem 1.2rem;
}

/* ===== Section Divider ===== */
.slide-section {
  background: var(--paper);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  position: relative;
  padding: 2.5rem 1.5rem;
  min-height: 35vh;
}
.slide-section::before {
  content: '';
  position: absolute; top: -30%; left: -20%;
  width: 80%; height: 160%;
  background: radial-gradient(ellipse at 40% 50%, rgba(107,124,94,.03), transparent 60%);
  pointer-events: none;
}
.slide-section .sec-num {
  font-size: .8em; letter-spacing: .4em;
  color: var(--zen-green); margin-bottom: .6em;
}
.slide-section h2 {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 1.3em; color: var(--ink-dark);
  letter-spacing: .15em; text-align: center;
}
.slide-section .sec-line {
  width: 50px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--bamboo), transparent);
  margin: .8em auto;
}
.slide-section .sec-sub {
  font-size: .85em; color: var(--ink-light);
  letter-spacing: .2em; text-align: center;
}

/* ===== Content Slide ===== */
.slide-content { background: var(--paper); display: flex; flex-direction: column; }
.slide-content .slide-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: .8rem; padding-bottom: .6rem;
  border-bottom: 1px solid rgba(107,124,94,.12);
}
.slide-content .slide-title {
  font-family: 'Ma Shan Zheng', cursive;
  font-size: 1.3em; color: var(--ink-dark);
  letter-spacing: .08em;
}
.slide-content .slide-pn {
  display: none;
  font-size: .65em; color: var(--ink-faint);
  letter-spacing: .1em;
}

/* ===== Footer ===== */
.slide-footer { display: none !important; }
.slide-footer .footer-project {
  font-size: .7em; color: var(--ink-faint);
  letter-spacing: .12em;
}
.slide-footer .footer-logo {
  position: absolute; right: 0; top: 50%; transform: translateY(-50%);
  height: 16px; width: auto; opacity: .5;
}
.slide-cover .cover-footer {
  position: absolute; bottom: 3%; left: 50%; transform: translateX(-50%);
  text-align: center;
}
.slide-cover .cover-footer img,
.slide-cover .cover-footer-inner img {
  height: 21px; width: auto; opacity: .55;
}

/* ===== Two column → Stack vertically ===== */
.layout-2col {
  display: grid; grid-template-columns: 1fr;
  gap: 1rem; flex: 1;
}
.layout-2col.text-img .col-text { grid-column: 1; }
.layout-2col.text-img .col-img {
  grid-column: 1;
  display: flex; align-items: stretch;
  min-height: 200px;
  order: -1;
}
.layout-2col.text-img .col-img img { width:100%; height:auto; display:block; }

.col-text h3 {
  font-size: .95em; color: var(--ink-mid);
  margin-bottom: .5em; margin-top: .8em;
  padding-left: .6em;
  border-left: 2px solid var(--zen-green);
  line-height: 1.5;
}
.col-text p, .col-text li {
  font-size: .82em; line-height: 1.8; color: var(--ink-mid);
}
.col-text ul { list-style: none; padding: 0; margin: .4em 0; }
.col-text li { padding-left: 1.2em; position: relative; margin-bottom: .3em; }
.col-text li::before { content: '\00b7'; position: absolute; left: 0; color: var(--zen-green); font-weight: 700; }
.col-text .summary-highlight {
  font-size: 1em; color: #c43b3b; font-weight: 600;
}

/* Full text layout → Stack vertically */
.layout-text {
  flex: 1;
  display: grid; grid-template-columns: 1fr;
  gap: 1rem; align-content: start;
}
.layout-text h3 {
  font-size: .9em; color: var(--ink-mid);
  margin-bottom: .5em; padding-left: .6em;
  border-left: 2px solid var(--zen-green);
}
.layout-text p, .layout-text li {
  font-size: .8em; line-height: 1.8; color: var(--ink-mid);
}
.layout-text ul { list-style: none; padding: 0; margin: .3em 0; }
.layout-text li { padding-left: 1.2em; position: relative; margin-bottom: .2em; }
.layout-text li::before { content: '\00b7'; position: absolute; left: 0; color: var(--zen-green); }

/* Quote box */
.quote-box {
  background: rgba(107,124,94,.04);
  border-left: 2px solid var(--zen-green);
  padding: .8em 1em; margin: .8em 0;
  font-style: italic; color: var(--ink-light);
  font-size: .85em; line-height: 1.8;
}
.quote-box.no-italic { font-style: normal; color: var(--ink-mid); }

/* Data table */
.data-table {
  width: 100%; border-collapse: collapse;
  font-size: .7em; margin: .5em 0;
  display: block; overflow-x: auto;
}
.data-table th {
  background: rgba(107,124,94,.05); color: var(--ink-mid);
  padding: .4em .5em; text-align: left;
  border-bottom: 1px solid rgba(107,124,94,.12);
  font-weight: 400; letter-spacing: .05em; white-space: nowrap;
}
.data-table td {
  padding: .35em .5em;
  border-bottom: 1px solid rgba(0,0,0,.04);
  color: var(--ink-mid);
}

.tag {
  display: inline-block;
  background: rgba(107,124,94,.06); color: var(--ink-mid);
  padding: .1em .5em; font-size: .72em;
  margin-right: .3em; border-radius: 1px;
}

.case-highlight {
  background: rgba(107,124,94,.06);
  border: 1px solid rgba(107,124,94,.12);
  border-radius: 3px; padding: .6em .8em; margin: .4em 0;
}
.case-highlight h4 { font-size: .8em; color: var(--zen-green); margin-bottom: .3em; letter-spacing: .05em; }
.case-highlight p { font-size: .72em; color: var(--ink-mid); line-height: 1.7; }

/* Image */
.layout-full-img { flex: 1; display: flex; align-items: center; justify-content: center; min-height: 200px; }
.layout-full-img > img { max-width: 100%; height: auto; }
.layout-full-img 








/* Top bar - Mobile */
.top-bar {
  position: sticky; top: 0; z-index: 100;
  background: rgba(51,51,51,.95);
  backdrop-filter: blur(10px);
  padding: .5rem .8rem;
  display: flex; flex-direction: column; gap: .3rem;
}
.nav-brand {
  font-family: 'Ma Shan Zheng', cursive;
  color: rgba(255,255,255,.85); font-size: .8rem;
  letter-spacing: .1em; text-align: center;
}
.top-bar .bar-actions { display: none; }
.top-bar button { display: none; }
.top-nav {
  display: flex; gap: .6rem; align-items: center;
  justify-content: center; flex-wrap: wrap;
}
.top-nav a {
  color: rgba(255,255,255,.7); text-decoration: none;
  font-size: .75rem; letter-spacing: .05em;
  padding: .15rem .3rem; white-space: nowrap;
}

.toc-sidebar { display: none !important; }

.progress-bar {
  position: fixed; top: 0; left: 0; height: 2px;
  background: var(--zen-green); z-index: 101;
  transition: width .1s;
}

@media print { body { display:none !important; } }

.sub-title {
  font-family: 'Noto Serif SC', serif;
  font-size: 1.1em;
  font-weight: 700;
  color: var(--ink-dark);
  letter-spacing: .06em;
  margin-right: .4em;
}

/* Mobile responsive images */
img { max-width: 100%; height: auto; }
.col-img { min-height: 220px !important; }
.slide .layout-full-img { min-height: 250px; }

/* ===== Mobile Floating TOC ===== */
.mobile-fab {
  position: fixed;
  bottom: 1.2rem; right: 1.2rem;
  width: 48px; height: 48px;
  background: rgba(51,51,51,.88);
  backdrop-filter: blur(8px);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: rgba(255,255,255,.85);
  box-shadow: 0 2px 12px rgba(0,0,0,.25);
  cursor: pointer;
  z-index: 200;
  transition: transform .2s, box-shadow .2s;
  -webkit-tap-highlight-color: transparent;
}
.mobile-fab:active { transform: scale(.92); }

.mobile-menu-overlay {
  display: none;
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.5);
  z-index: 300;
  justify-content: flex-end;
  opacity: 0;
  transition: opacity .3s;
}
.mobile-menu-overlay.active { opacity: 1; }

.mobile-menu-panel {
  width: 80%; max-width: 320px;
  height: 100%;
  background: #faf8f3;
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform .3s ease;
  box-shadow: -4px 0 20px rgba(0,0,0,.15);
}
.mobile-menu-overlay.active .mobile-menu-panel {
  transform: translateX(0);
}

.mobile-menu-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 1rem 1.2rem;
  border-bottom: 1px solid rgba(107,124,94,.15);
  background: rgba(51,51,51,.95);
}
.mobile-menu-title {
  font-family: 'Ma Shan Zheng', cursive;
  color: rgba(255,255,255,.9);
  font-size: 1.1rem;
  letter-spacing: .1em;
}
.mobile-menu-close {
  background: none; border: none;
  color: rgba(255,255,255,.7);
  font-size: 1.8rem;
  cursor: pointer;
  padding: 0 .3rem;
  line-height: 1;
  -webkit-tap-highlight-color: transparent;
}

.mobile-menu-body {
  flex: 1; overflow-y: auto;
  padding: .5rem 0;
  -webkit-overflow-scrolling: touch;
}
.mobile-menu-body a {
  display: block;
  padding: .65rem 1.2rem;
  color: var(--ink-mid);
  text-decoration: none;
  font-size: .88rem;
  letter-spacing: .05em;
  border-bottom: 1px solid rgba(0,0,0,.03);
  transition: background .15s;
  -webkit-tap-highlight-color: transparent;
}
.mobile-menu-body a:active {
  background: rgba(107,124,94,.08);
}
.mobile-menu-divider {
  padding: .5rem 1.2rem .3rem;
  font-size: .72rem;
  color: var(--zen-green);
  font-weight: 600;
  letter-spacing: .15em;
  background: rgba(107,124,94,.04);
}


/* 占位框样式 */
.placeholder-box {
  background: #f8f8f5;
  border: 2px dashed #ccc;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  aspect-ratio: 1/1;
  max-height: 500px;
  padding: 1.5rem;
  box-sizing: border-box;
}
.ph-label {
  font-size: 1em;
  color: #666;
  margin-bottom: 0.5rem;
}
.ph-size {
  font-size: 0.85em;
  color: #999;
}

.slide img {
  pointer-events: none;
  -webkit-user-drag: none;
  user-drag: none;
  -webkit-touch-callout: none;
  user-select: none;
}
</style>
